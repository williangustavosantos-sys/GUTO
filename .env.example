# Dev local: o app usa proxy /api/guto → backend (sem CORS no browser).
# Suba o backend: cd guto-backend && npm run dev  (porta 3001)
GUTO_BACKEND_PROXY_URL=http://localhost:3001
NEXT_PUBLIC_API_URL=http://localhost:3001

# Para apontar o proxy local para Render (sem mudar código):
# GUTO_BACKEND_PROXY_URL=https://cerebroguto.onrender.com
# NEXT_PUBLIC_API_URL=https://cerebroguto.onrender.com
